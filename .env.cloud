# ========================================
# AutoScript-Pro - Cloud Configuration
# ========================================
# Copy this file to .env and configure for your cloud environment

# ----------------------------------------
# Flask Application Settings
# ----------------------------------------
FLASK_DEBUG=False
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
SECRET_KEY=your-super-secure-secret-key-here-change-this

# ----------------------------------------
# MongoDB Database Configuration
# ----------------------------------------
# For cloud MongoDB (MongoDB Atlas, Azure Cosmos DB, etc.)
MONGO_URI=mongodb://your-cloud-mongodb-host:27017/terraform_ai_agent
# Alternative for MongoDB Atlas:
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/terraform_ai_agent?retryWrites=true&w=majority

MONGO_DB_NAME=terraform_ai_agent

# ----------------------------------------
# Initial User Setup (Optional)
# ----------------------------------------
# Format: username1:password1,username2:password2
INITIAL_USERS=admin@autoscript.dev:admin123,user@autoscript.dev:user123

# ----------------------------------------
# Azure OpenAI Configuration
# ----------------------------------------
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ----------------------------------------
# Azure Service Principal (for Terraform)
# ----------------------------------------
AZURE_CLIENT_ID=your_service_principal_client_id_here
AZURE_CLIENT_SECRET=your_service_principal_client_secret_here
AZURE_TENANT_ID=your_azure_tenant_id_here
AZURE_SUBSCRIPTION_ID=your_azure_subscription_id_here

# ----------------------------------------
# AWS Credentials (Optional - for AWS support)
# ----------------------------------------
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_DEFAULT_REGION=us-east-1

# ----------------------------------------
# GitHub Integration (Optional)
# ----------------------------------------
# These are set by users at runtime, but can be pre-configured
# GITHUB_TOKEN=your_github_personal_access_token_here
# GITHUB_REPO_URL=https://github.com/your-org/your-repo

# ----------------------------------------
# Logging Configuration
# ----------------------------------------
LOG_LEVEL=INFO
LOG_FILE=./logs/autoscript-pro.log

# ----------------------------------------
# Security Settings
# ----------------------------------------
# Session timeout in minutes
SESSION_TIMEOUT=60

# Maximum file upload size (for future features)
MAX_CONTENT_LENGTH=16777216

# ----------------------------------------
# Cloud Provider Specific Settings
# ----------------------------------------
# Default cloud provider (aws or azure)
DEFAULT_CLOUD_PROVIDER=azure

# Terraform state backend configuration
# TERRAFORM_BACKEND_TYPE=azurerm
# TERRAFORM_BACKEND_STORAGE_ACCOUNT=your_storage_account
# TERRAFORM_BACKEND_CONTAINER_NAME=tfstate
# TERRAFORM_BACKEND_KEY=terraform.tfstate
